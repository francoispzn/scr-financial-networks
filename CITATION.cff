        given-names: F.
      - family-names: Aste
        given-names: T.
    title: "Spectral coarse graining and rescaling for preserving structural and dynamical properties in graphs"
    journal: "Physical Review E"
    volume: 112
    pages: "034303"
    year: 2025
    doi: "10.1103/PhysRevE.112.034303"
